        delete from fire_maintenance_record where record_id = #{recordId}
    </delete>

    <delete id="deleteFireMaintenanceRecordByRecordIds" parameterType="String">
        delete from fire_maintenance_record where record_id in 
        <foreach item="recordId" collection="array" open="(" separator="," close=")">
            #{recordId}
        </foreach>
    </delete>

    <delete id="deleteFireMaintenanceRecordByTaskId" parameterType="Long">
        delete from fire_maintenance_record where task_id = #{taskId}
    </delete>

    <update id="completeAllByTaskId" parameterType="Long">
        update fire_maintenance_record
        set check_result = '1', check_time = sysdate()
        where task_id = #{taskId} and level = 3 and (check_result = '0' or check_result is null)
    </update>
