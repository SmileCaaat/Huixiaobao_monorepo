            <if test="sitePhotos != null">site_photos,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskId != null">#{taskId},</if>
            <if test="templateId != null">#{templateId},</if>
            <if test="level != null">#{level},</if>
            <if test="parentRecordId != null">#{parentRecordId},</if>
            <if test="itemName != null and itemName != ''">#{itemName},</if>
            <if test="itemCode != null and itemCode != ''">#{itemCode},</if>
            <if test="checkResult != null">#{checkResult},</if>
            <if test="faultDescription != null">#{faultDescription},</if>
            <if test="faultImages != null">#{faultImages},</if>
            <if test="repairSuggestion != null">#{repairSuggestion},</if>
