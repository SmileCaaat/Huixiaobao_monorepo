    <sql id="selectFireMaintenanceRecordVo">
        select record_id, task_id, template_id, level, parent_record_id, item_name, item_code, check_result, fault_description, fault_images, repair_suggestion, other_notes, check_time, checker_id, checker_name, sort_order, record_type, device_location, test_situation, test_time, test_result, site_photos, create_time, update_time from fire_maintenance_record
    </sql>

    <select id="selectFireMaintenanceRecordList" parameterType="FireMaintenanceRecord" resultMap="FireMaintenanceRecordResult">
        <include refid="selectFireMaintenanceRecordVo"/>
        <where>  
            <if test="taskId != null "> and task_id = #{taskId}</if>
            <if test="templateId != null "> and template_id = #{templateId}</if>
            <if test="level != null "> and level = #{level}</if>
            <if test="parentRecordId != null "> and parent_record_id = #{parentRecordId}</if>
            <if test="itemName != null  and itemName != ''"> and item_name like concat('%', #{itemName}, '%')</if>
            <if test="itemCode != null  and itemCode != ''"> and item_code = #{itemCode}</if>
            <if test="checkResult != null  and checkResult != ''"> and check_result = #{checkResult}</if>
            <if test="recordType != null  and recordType != ''"> and record_type = #{recordType}</if>
        </where>
        order by level, sort_order
    </select>
    
    <select id="selectFireMaintenanceRecordByRecordId" parameterType="Long" resultMap="FireMaintenanceRecordResult">
        <include refid="selectFireMaintenanceRecordVo"/>
        where record_id = #{recordId}
    </select>

    <select id="selectByTaskIdAndLevel" resultMap="FireMaintenanceRecordResult">
        <include refid="selectFireMaintenanceRecordVo"/>
        where task_id = #{taskId} and level = #{level}
        order by sort_order
    </select>

    <select id="selectByTaskIdAndParentId" resultMap="FireMaintenanceRecordResult">
        <include refid="selectFireMaintenanceRecordVo"/>
        where task_id = #{taskId} and parent_record_id = #{parentRecordId} and level = #{level}
        order by sort_order
    </select>

    <select id="selectLevel3ByTaskId" parameterType="Long" resultMap="FireMaintenanceRecordResult">
        <include refid="selectFireMaintenanceRecordVo"/>
        where task_id = #{taskId} and level = 3
        order by sort_order
    </select>

    <select id="selectRecordsByTaskId" parameterType="Long" resultMap="FireMaintenanceRecordResult">
        <include refid="selectFireMaintenanceRecordVo"/>
        where task_id = #{taskId}
        order by level, sort_order
    </select>
        
    <insert id="insertFireMaintenanceRecord" parameterType="FireMaintenanceRecord" useGeneratedKeys="true" keyProperty="recordId">
        insert into fire_maintenance_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskId != null">task_id,</if>
            <if test="templateId != null">template_id,</if>
            <if test="level != null">level,</if>
            <if test="parentRecordId != null">parent_record_id,</if>
            <if test="itemName != null and itemName != ''">item_name,</if>
            <if test="itemCode != null and itemCode != ''">item_code,</if>
            <if test="checkResult != null">check_result,</if>
            <if test="faultDescription != null">fault_description,</if>
            <if test="faultImages != null">fault_images,</if>
            <if test="repairSuggestion != null">repair_suggestion,</if>
            <if test="otherNotes != null">other_notes,</if>
            <if test="checkTime != null">check_time,</if>
            <if test="checkerId != null">checker_id,</if>
