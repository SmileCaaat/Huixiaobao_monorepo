            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <insert id="batchInsertFireMaintenanceRecord" parameterType="java.util.List" useGeneratedKeys="true" keyProperty="recordId">
        insert into fire_maintenance_record(task_id, template_id, level, parent_record_id, item_name, item_code, check_result, sort_order, record_type, create_time)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.taskId}, #{item.templateId}, #{item.level}, #{item.parentRecordId}, #{item.itemName}, #{item.itemCode}, #{item.checkResult}, #{item.sortOrder}, #{item.recordType}, now())
        </foreach>
    </insert>

    <update id="updateFireMaintenanceRecord" parameterType="FireMaintenanceRecord">
        update fire_maintenance_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="taskId != null">task_id = #{taskId},</if>
            <if test="templateId != null">template_id = #{templateId},</if>
            <if test="level != null">level = #{level},</if>
            <if test="parentRecordId != null">parent_record_id = #{parentRecordId},</if>
            <if test="itemName != null and itemName != ''">item_name = #{itemName},</if>
            <if test="itemCode != null and itemCode != ''">item_code = #{itemCode},</if>
            <if test="checkResult != null">check_result = #{checkResult},</if>
            <if test="faultDescription != null">fault_description = #{faultDescription},</if>
            <if test="faultImages != null">fault_images = #{faultImages},</if>
