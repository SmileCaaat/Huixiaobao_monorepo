<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.fire.mapper.FireSystemTypeMapper">
    
    <resultMap type="FireSystemType" id="FireSystemTypeResult">
        <result property="typeId"     column="type_id"     />
        <result property="typeCode"   column="type_code"   />
        <result property="typeName"   column="type_name"   />
        <result property="parentId"   column="parent_id"   />
        <result property="orderNum"   column="order_num"   />
        <result property="icon"       column="icon"        />
        <result property="status"     column="status"      />
        <result property="remark"     column="remark"      />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"   column="create_by"   />
        <result property="createTime" column="create_time" />
        <result property="updateBy"   column="update_by"   />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectFireSystemTypeVo">
        select type_id, type_code, type_name, parent_id, order_num, icon, status, remark, del_flag, create_by, create_time, update_by, update_time
        from fire_system_type
    </sql>

    <select id="selectFireSystemTypeById" parameterType="Long" resultMap="FireSystemTypeResult">
        <include refid="selectFireSystemTypeVo"/>
        where type_id = #{typeId} and del_flag = '0'
    </select>

    <select id="selectFireSystemTypeList" parameterType="FireSystemType" resultMap="FireSystemTypeResult">
        <include refid="selectFireSystemTypeVo"/>
        <where>
            del_flag = '0'
            <if test="typeCode != null and typeCode != ''">
                AND type_code like concat('%', #{typeCode}, '%')
            </if>
            <if test="typeName != null and typeName != ''">
                AND type_name like concat('%', #{typeName}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="parentId != null">
                AND parent_id = #{parentId}
            </if>
        </where>
        order by order_num asc
    </select>

    <select id="selectFireSystemTypeAll" resultMap="FireSystemTypeResult">
        <include refid="selectFireSystemTypeVo"/>
        where status = '0' and del_flag = '0'
        order by order_num asc
    </select>

    <select id="checkTypeCodeUnique" parameterType="String" resultMap="FireSystemTypeResult">
        <include refid="selectFireSystemTypeVo"/>
        where type_code = #{typeCode} and del_flag = '0' limit 1
    </select>

    <select id="checkTypeNameUnique" parameterType="String" resultMap="FireSystemTypeResult">
        <include refid="selectFireSystemTypeVo"/>
        where type_name = #{typeName} and del_flag = '0' limit 1
    </select>

    <insert id="insertFireSystemType" parameterType="FireSystemType" useGeneratedKeys="true" keyProperty="typeId">
        insert into fire_system_type
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="typeCode != null">type_code,</if>
            <if test="typeName != null">type_name,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="icon != null">icon,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="typeCode != null">#{typeCode},</if>
            <if test="typeName != null">#{typeName},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="icon != null">#{icon},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateFireSystemType" parameterType="FireSystemType">
        update fire_system_type
        <trim prefix="SET" suffixOverrides=",">
            <if test="typeCode != null">type_code = #{typeCode},</if>
            <if test="typeName != null">type_name = #{typeName},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where type_id = #{typeId}
    </update>

    <update id="deleteFireSystemTypeById" parameterType="Long">
        update fire_system_type set del_flag = '2' where type_id = #{typeId}
    </update>

    <update id="deleteFireSystemTypeByIds" parameterType="Long">
        update fire_system_type set del_flag = '2' where type_id in
        <foreach item="typeId" collection="array" open="(" separator="," close=")">
            #{typeId}
        </foreach>
    </update>

</mapper>
