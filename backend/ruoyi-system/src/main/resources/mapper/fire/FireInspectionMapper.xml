<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.fire.mapper.FireInspectionMapper">
    
    <resultMap type="FireInspection" id="FireInspectionResult">
        <result property="inspectionId"    column="inspection_id"    />
        <result property="companyId"       column="company_id"       />
        <result property="companyName"     column="company_name"     />
        <result property="inspectionType"  column="inspection_type"  />
        <result property="buildingId"      column="building_id"      />
        <result property="buildingName"    column="building_name"    />
        <result property="floor"           column="floor"            />
        <result property="systemType"      column="system_type"      />
        <result property="systemName"      column="system_name"      />
        <result property="equipmentName"   column="equipment_name"   />
        <result property="equipmentCount"  column="equipment_count"  />
        <result property="location"        column="location"         />
        <result property="inspectionTime"  column="inspection_time"  />
        <result property="equipmentStatus" column="equipment_status" />
        <result property="inspectorId"     column="inspector_id"     />
        <result property="inspectorName"   column="inspector_name"   />
        <result property="imageUrls"       column="image_urls"       />
        <result property="taskId"          column="task_id"          />
        <result property="remark"          column="remark"           />
        <result property="delFlag"         column="del_flag"         />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
    </resultMap>

    <sql id="selectFireInspectionVo">
        select inspection_id, company_id, company_name, inspection_type, building_id, building_name, 
               floor, system_type, system_name, equipment_name, equipment_count, location, 
               inspection_time, equipment_status, inspector_id, inspector_name, image_urls, 
               task_id, remark, del_flag, create_by, create_time, update_by, update_time
        from fire_inspection
    </sql>

    <select id="selectFireInspectionById" parameterType="Long" resultMap="FireInspectionResult">
        <include refid="selectFireInspectionVo"/>
        where inspection_id = #{inspectionId} and del_flag = '0'
    </select>

    <select id="selectFireInspectionList" parameterType="FireInspection" resultMap="FireInspectionResult">
        <include refid="selectFireInspectionVo"/>
        <where>
            del_flag = '0'
            <if test="companyId != null">
                AND company_id = #{companyId}
            </if>
            <if test="companyName != null and companyName != ''">
                AND company_name like concat('%', #{companyName}, '%')
            </if>
            <if test="inspectionType != null and inspectionType != ''">
                AND inspection_type = #{inspectionType}
            </if>
            <if test="buildingId != null">
                AND building_id = #{buildingId}
            </if>
            <if test="buildingName != null and buildingName != ''">
                AND building_name like concat('%', #{buildingName}, '%')
            </if>
            <if test="systemType != null and systemType != ''">
                AND system_type = #{systemType}
            </if>
            <if test="systemName != null and systemName != ''">
                AND system_name like concat('%', #{systemName}, '%')
            </if>
            <if test="equipmentName != null and equipmentName != ''">
                AND equipment_name like concat('%', #{equipmentName}, '%')
            </if>
            <if test="equipmentStatus != null and equipmentStatus != ''">
                AND equipment_status = #{equipmentStatus}
            </if>
            <if test="inspectorId != null">
                AND inspector_id = #{inspectorId}
            </if>
            <if test="inspectorName != null and inspectorName != ''">
                AND inspector_name like concat('%', #{inspectorName}, '%')
            </if>
            <if test="taskId != null">
                AND task_id = #{taskId}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                AND inspection_time &gt;= #{params.beginTime}
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                AND inspection_time &lt;= #{params.endTime}
            </if>
        </where>
        order by inspection_time desc
    </select>

    <select id="selectFireInspectionByCompanyId" parameterType="Long" resultMap="FireInspectionResult">
        <include refid="selectFireInspectionVo"/>
        where company_id = #{companyId} and del_flag = '0'
        order by inspection_time desc
    </select>

    <insert id="insertFireInspection" parameterType="FireInspection" useGeneratedKeys="true" keyProperty="inspectionId">
        insert into fire_inspection
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="companyId != null">company_id,</if>
            <if test="companyName != null">company_name,</if>
            <if test="inspectionType != null">inspection_type,</if>
            <if test="buildingId != null">building_id,</if>
            <if test="buildingName != null">building_name,</if>
            <if test="floor != null">floor,</if>
            <if test="systemType != null">system_type,</if>
            <if test="systemName != null">system_name,</if>
            <if test="equipmentName != null">equipment_name,</if>
            <if test="equipmentCount != null">equipment_count,</if>
            <if test="location != null">location,</if>
            <if test="inspectionTime != null">inspection_time,</if>
            <if test="equipmentStatus != null">equipment_status,</if>
            <if test="inspectorId != null">inspector_id,</if>
            <if test="inspectorName != null">inspector_name,</if>
            <if test="imageUrls != null">image_urls,</if>
            <if test="taskId != null">task_id,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="companyId != null">#{companyId},</if>
            <if test="companyName != null">#{companyName},</if>
            <if test="inspectionType != null">#{inspectionType},</if>
            <if test="buildingId != null">#{buildingId},</if>
            <if test="buildingName != null">#{buildingName},</if>
            <if test="floor != null">#{floor},</if>
            <if test="systemType != null">#{systemType},</if>
            <if test="systemName != null">#{systemName},</if>
            <if test="equipmentName != null">#{equipmentName},</if>
            <if test="equipmentCount != null">#{equipmentCount},</if>
            <if test="location != null">#{location},</if>
            <if test="inspectionTime != null">#{inspectionTime},</if>
            <if test="equipmentStatus != null">#{equipmentStatus},</if>
            <if test="inspectorId != null">#{inspectorId},</if>
            <if test="inspectorName != null">#{inspectorName},</if>
            <if test="imageUrls != null">#{imageUrls},</if>
            <if test="taskId != null">#{taskId},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateFireInspection" parameterType="FireInspection">
        update fire_inspection
        <trim prefix="SET" suffixOverrides=",">
            <if test="companyId != null">company_id = #{companyId},</if>
            <if test="companyName != null">company_name = #{companyName},</if>
            <if test="inspectionType != null">inspection_type = #{inspectionType},</if>
            <if test="buildingId != null">building_id = #{buildingId},</if>
            <if test="buildingName != null">building_name = #{buildingName},</if>
            <if test="floor != null">floor = #{floor},</if>
            <if test="systemType != null">system_type = #{systemType},</if>
            <if test="systemName != null">system_name = #{systemName},</if>
            <if test="equipmentName != null">equipment_name = #{equipmentName},</if>
            <if test="equipmentCount != null">equipment_count = #{equipmentCount},</if>
            <if test="location != null">location = #{location},</if>
            <if test="inspectionTime != null">inspection_time = #{inspectionTime},</if>
            <if test="equipmentStatus != null">equipment_status = #{equipmentStatus},</if>
            <if test="inspectorId != null">inspector_id = #{inspectorId},</if>
            <if test="inspectorName != null">inspector_name = #{inspectorName},</if>
            <if test="imageUrls != null">image_urls = #{imageUrls},</if>
            <if test="taskId != null">task_id = #{taskId},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where inspection_id = #{inspectionId}
    </update>

    <update id="deleteFireInspectionById" parameterType="Long">
        update fire_inspection set del_flag = '2' where inspection_id = #{inspectionId}
    </update>

    <update id="deleteFireInspectionByIds" parameterType="Long">
        update fire_inspection set del_flag = '2' where inspection_id in
        <foreach item="inspectionId" collection="array" open="(" separator="," close=")">
            #{inspectionId}
        </foreach>
    </update>

    <select id="selectInspectionTestByCompanyIdAndTimeRange" resultMap="FireInspectionResult">
        <include refid="selectFireInspectionVo"/>
        where company_id = #{companyId} 
          and del_flag = '0'
          and inspection_time &gt;= #{startTime}
        order by inspection_time desc
    </select>

</mapper>
