
.page.data-v-a961c2a9 {
  width: 100vw;
  height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.nav-right.data-v-a961c2a9 {
  padding: 0 20rpx;
}

/* 内容区域 */
.content.data-v-a961c2a9 {
  padding-right: 20rpx;
  padding-left: 20rpx;
  flex: 1;
  padding-top: calc(16px + env(safe-area-inset-top));
  box-sizing: border-box;
}

/* 类型列表 */
.type-list.data-v-a961c2a9 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 20rpx;
}
.type-item.data-v-a961c2a9 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.type-item.data-v-a961c2a9:active {
  background: #f5f5f5;
}
.type-name.data-v-a961c2a9 {
  font-size: 30rpx;
  color: #333;
}
.type-right.data-v-a961c2a9 {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.type-count.data-v-a961c2a9 {
  font-size: 28rpx;
  color: #999;
}
.arrow.data-v-a961c2a9 {
  font-size: 32rpx;
  color: #ccc;
}

/* 空状态 */
.empty-state.data-v-a961c2a9 {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}
.empty-text.data-v-a961c2a9 {
  font-size: 28rpx;
  color: #999;
}

/* 添加按钮 */
.add-btn.data-v-a961c2a9 {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #e53935 0%, #ef5350 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(229, 57, 53, 0.4);
  z-index: 100;
}
.add-icon.data-v-a961c2a9 {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
}

/* 覆盖 uni-nav-bar 标题样式 */
.data-v-a961c2a9 .uni-nav-bar-text {
  font-size: 36rpx !important;
  font-weight: bold !important;
}

/* 让标题容器绝对定位实现真正居中 */
.data-v-a961c2a9 .uni-navbar__header-container {
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  display: flex !important;
  justify-content: center !important;
  pointer-events: none;
}
.data-v-a961c2a9 .uni-navbar__header-container-inner {
  pointer-events: auto;
}

/* 确保左侧按钮在标题容器之上可点击 */
.data-v-a961c2a9 .uni-navbar__header-btns-left {
  z-index: 10 !important;
  position: relative !important;
}
