
.page.data-v-0233bbef {
  width: 100%;
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}
.content.data-v-0233bbef {
  flex: 1;
  padding: 20rpx;
  padding-top: calc(16px + env(safe-area-inset-top) + 20rpx);
  box-sizing: border-box;
}

/* 表单容器 */
.form-container.data-v-0233bbef {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: 40rpx;
}
.system-input-wrapper.data-v-0233bbef {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.flex-1.data-v-0233bbef {
  flex: 1;
}
.preset-picker.data-v-0233bbef {
  flex-shrink: 0;
}
.preset-btn.data-v-0233bbef {
  padding: 10rpx 24rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #e53935;
  border: 1rpx solid #ddd;
}

/* 选择器包装 */
.picker-wrapper.data-v-0233bbef {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 70rpx;
}
.picker-wrapper .placeholder.data-v-0233bbef {
  color: #999;
  font-size: 28rpx;
}
.picker-wrapper .arrow.data-v-0233bbef {
  color: #ccc;
  font-size: 32rpx;
}

/* 备注输入框 */
.remark-input.data-v-0233bbef {
  width: 100%;
  height: 160rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

/* 保存按钮 */
.save-btn.data-v-0233bbef {
  margin-top: 40rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #e53935 0%, #ef5350 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.save-btn text.data-v-0233bbef {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 图片上传 */
.upload-section.data-v-0233bbef {
  margin-top: 20rpx;
  padding: 0 0 10rpx;
}
.upload-grid.data-v-0233bbef {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.upload-item.data-v-0233bbef,
.upload-btn.data-v-0233bbef {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  position: relative;
}
.upload-item image.data-v-0233bbef {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}
.delete-icon.data-v-0233bbef {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
.upload-btn.data-v-0233bbef {
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
}

/* 选择器弹窗 */
.picker-mask.data-v-0233bbef {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}
.picker-popup.data-v-0233bbef {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}
.picker-header.data-v-0233bbef {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}
.picker-header text.data-v-0233bbef {
  font-size: 28rpx;
  color: #e53935;
}
.picker-title.data-v-0233bbef {
  color: #333 !important;
  font-weight: bold;
}
.picker-view.data-v-0233bbef {
  height: 400rpx;
}
.picker-item.data-v-0233bbef {
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
}

/* 覆盖 uni-nav-bar 样式 */
.data-v-0233bbef .uni-nav-bar-text {
  font-size: 36rpx !important;
  font-weight: bold !important;
}
.data-v-0233bbef .uni-navbar__header-container {
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  display: flex !important;
  justify-content: center !important;
  pointer-events: none;
}
.data-v-0233bbef .uni-navbar__header-container-inner {
  pointer-events: auto;
}
.data-v-0233bbef .uni-navbar__header-btns-left {
  z-index: 10 !important;
  position: relative !important;
}

/* uni-forms 样式调整 */
.data-v-0233bbef .uni-forms-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.data-v-0233bbef .uni-forms-item__label {
  font-size: 28rpx !important;
  color: #333 !important;
}
.data-v-0233bbef .uni-easyinput__content {
  border: none !important;
  background: transparent !important;
}
.data-v-0233bbef .uni-easyinput__content-input {
  font-size: 28rpx !important;
}
