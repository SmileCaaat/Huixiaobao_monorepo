
.page.data-v-71d9c6ae {
  width: 100vw;
  height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 内容区域 */
.content.data-v-71d9c6ae {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-top: calc(16px + env(safe-area-inset-top));
  overflow: hidden;
}

/* 筛选区域 */
.filter-section.data-v-71d9c6ae {
  background: #fff;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

/* 搜索框 */
.search-box.data-v-71d9c6ae {
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  margin-bottom: 20rpx;
}
.search-input.data-v-71d9c6ae {
  width: 100%;
  font-size: 28rpx;
  color: #333;
}
.search-input.data-v-71d9c6ae::-moz-placeholder {
  color: #999;
}
.search-input.data-v-71d9c6ae::placeholder {
  color: #999;
}

/* 筛选行 */
.filter-row.data-v-71d9c6ae {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}
.filter-label.data-v-71d9c6ae {
  font-size: 28rpx;
  color: #333;
  width: 200rpx;
  flex-shrink: 0;
}
.filter-options.data-v-71d9c6ae {
  display: flex;
  align-items: center;
  gap: 40rpx;
  flex: 1;
}
.filter-option.data-v-71d9c6ae {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.filter-option text.data-v-71d9c6ae {
  font-size: 28rpx;
  color: #666;
}

/* 复选框样式 */
.checkbox.data-v-71d9c6ae {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #1976d2;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.checkbox.checked.data-v-71d9c6ae {
  background: #1976d2;
}
.check-icon.data-v-71d9c6ae {
  color: #fff;
  font-size: 24rpx;
}

/* 单选框样式 */
.radio.data-v-71d9c6ae {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #999;
  border-radius: 50%;
}
.radio.checked.data-v-71d9c6ae {
  border-color: #1976d2;
  background: #fff;
  position: relative;
}
.radio.checked.data-v-71d9c6ae::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 18rpx;
  height: 18rpx;
  background: #1976d2;
  border-radius: 50%;
}

/* 列表容器 */
.list-container.data-v-71d9c6ae {
  flex: 1;
  padding: 0 20rpx 20rpx;
  box-sizing: border-box;
}

/* 设备卡片 */
.equipment-card.data-v-71d9c6ae {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.card-header.data-v-71d9c6ae {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.equipment-name.data-v-71d9c6ae {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.equipment-date.data-v-71d9c6ae {
  font-size: 24rpx;
  color: #999;
}
.card-content.data-v-71d9c6ae {
  padding: 20rpx 30rpx;
}
.info-row.data-v-71d9c6ae {
  display: flex;
  margin-bottom: 16rpx;
}
.info-row.data-v-71d9c6ae:last-child {
  margin-bottom: 0;
}
.info-item.data-v-71d9c6ae {
  flex: 1;
  display: flex;
  align-items: flex-start;
}
.info-item.right.data-v-71d9c6ae {
  justify-content: flex-end;
}
.info-item.full.data-v-71d9c6ae {
  flex: none;
  width: 100%;
}
.info-label.data-v-71d9c6ae {
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.info-value.data-v-71d9c6ae {
  font-size: 26rpx;
  color: #333;
}
.text-warning.data-v-71d9c6ae {
  color: #e53935;
}
.text-normal.data-v-71d9c6ae {
  color: #4caf50;
}

/* 空状态 */
.empty-state.data-v-71d9c6ae {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}
.empty-text.data-v-71d9c6ae {
  font-size: 28rpx;
  color: #999;
}

/* 覆盖 uni-nav-bar 标题样式 */
.data-v-71d9c6ae .uni-nav-bar-text {
  font-size: 36rpx !important;
  font-weight: bold !important;
}
.data-v-71d9c6ae .uni-navbar__header-container {
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  display: flex !important;
  justify-content: center !important;
  pointer-events: none;
}
.data-v-71d9c6ae .uni-navbar__header-container-inner {
  pointer-events: auto;
}
.data-v-71d9c6ae .uni-navbar__header-btns-left {
  z-index: 10 !important;
  position: relative !important;
}
