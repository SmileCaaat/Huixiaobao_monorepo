
.page.data-v-9daf322d {
  width: 100vw;
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}
.content.data-v-9daf322d {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  padding-top: calc(16px + env(safe-area-inset-top));
  background: #f5f5f5;
  box-sizing: border-box;
}

/* Tab 切换按钮组 */
.tab.data-v-9daf322d {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  flex-shrink: 0;
}
.tab-item.data-v-9daf322d {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  background: #fff;
  transition: all 0.3s;
}
.tab-item.active.data-v-9daf322d {
  color: #e53935;
  font-weight: bold;
  background: rgba(229, 57, 53, 0.08);
}
.tab-item.active.data-v-9daf322d::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #e53935;
  border-radius: 2rpx;
}

/* 表单容器 */
.form-container.data-v-9daf322d {
  width: 94%;
  flex: 1;
  margin-top: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: 40rpx;
}
.system-input-wrapper.data-v-9daf322d {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.flex-1.data-v-9daf322d {
  flex: 1;
}
.preset-picker.data-v-9daf322d {
  flex-shrink: 0;
}
.preset-btn.data-v-9daf322d {
  padding: 10rpx 24rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #e53935;
  border: 1rpx solid #ddd;
}

/* 选择器包装 */
.picker-wrapper.data-v-9daf322d {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 70rpx;
}
.picker-wrapper .placeholder.data-v-9daf322d {
  color: #999;
  font-size: 28rpx;
}
.picker-wrapper .arrow.data-v-9daf322d {
  color: #ccc;
  font-size: 32rpx;
}

/* 保存按钮 */
.save-btn.data-v-9daf322d {
  margin-top: 30rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #e53935 0%, #ef5350 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.save-btn text.data-v-9daf322d {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 图片上传 */
.upload-section.data-v-9daf322d {
  margin-top: 20rpx;
  padding: 0 0 10rpx;
}
.upload-label.data-v-9daf322d {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}
.upload-grid.data-v-9daf322d {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.upload-item.data-v-9daf322d,
.upload-btn.data-v-9daf322d {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  position: relative;
}
.upload-item image.data-v-9daf322d {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}
.delete-icon.data-v-9daf322d {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
.upload-btn.data-v-9daf322d {
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
}

/* 遮罩和弹窗 */
.picker-mask.data-v-9daf322d {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.picker-popup.data-v-9daf322d {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}
.picker-header.data-v-9daf322d {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #eee;
}
.picker-title.data-v-9daf322d {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}
.picker-header text.data-v-9daf322d:first-child {
  color: #999;
  font-size: 28rpx;
}
.picker-header text.data-v-9daf322d:last-child {
  color: #e53935;
  font-size: 28rpx;
}
.picker-view.data-v-9daf322d {
  width: 100%;
  height: 500rpx;
}
.picker-item.data-v-9daf322d {
  line-height: 80rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333;
}
.scan-placeholder text.data-v-9daf322d {
  font-size: 28rpx;
  color: #666;
}
.scan-btn.data-v-9daf322d {
  margin-top: 40rpx;
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #e53935 0%, #ef5350 100%);
  border-radius: 40rpx;
  display: inline-flex;
}
.scan-btn text.data-v-9daf322d {
  color: #fff;
  font-size: 28rpx;
}

/* 选择器弹窗 */
.picker-mask.data-v-9daf322d {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}
.picker-popup.data-v-9daf322d {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}
.picker-header.data-v-9daf322d {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}
.picker-header text.data-v-9daf322d {
  font-size: 28rpx;
  color: #e53935;
}
.picker-title.data-v-9daf322d {
  color: #333 !important;
  font-weight: bold;
}
.picker-view.data-v-9daf322d {
  height: 400rpx;
}
.picker-item.data-v-9daf322d {
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
}

/* 覆盖 uni-nav-bar 标题样式 */
.data-v-9daf322d .uni-nav-bar-text {
  font-size: 36rpx !important;
  font-weight: bold !important;
}

/* 让标题容器绝对定位实现真正居中 */
.data-v-9daf322d .uni-navbar__header-container {
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  display: flex !important;
  justify-content: center !important;
  pointer-events: none;
}
.data-v-9daf322d .uni-navbar__header-container-inner {
  pointer-events: auto;
}

/* 确保左侧按钮在标题容器之上可点击 */
.data-v-9daf322d .uni-navbar__header-btns-left {
  z-index: 10 !important;
  position: relative !important;
}

/* uni-forms 样式调整 */
.data-v-9daf322d .uni-forms-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.data-v-9daf322d .uni-forms-item__label {
  font-size: 28rpx !important;
  color: #333 !important;
}
.data-v-9daf322d .uni-easyinput__content {
  border: none !important;
  background: transparent !important;
}
.data-v-9daf322d .uni-easyinput__content-input {
  font-size: 28rpx !important;
}
