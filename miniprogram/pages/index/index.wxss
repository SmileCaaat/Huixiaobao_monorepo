
.page.data-v-83a5a03c {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部横幅 */
.banner.data-v-83a5a03c {
  background: linear-gradient(135deg, #e53935 0%, #ef5350 100%);
  padding: 80rpx 30rpx 40rpx;
  padding-top: calc(80rpx + env(safe-area-inset-top));
  border-radius: 0 0 40rpx 40rpx;
}
.banner-content.data-v-83a5a03c {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.banner-text.data-v-83a5a03c {
  display: flex;
  flex-direction: column;
}
.banner-title.data-v-83a5a03c {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}
.banner-desc.data-v-83a5a03c {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}
.banner-img.data-v-83a5a03c {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx;
}

/* 轮播图 */
.swiper.data-v-83a5a03c {
  height: 200rpx;
  margin-top: 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.swiper-slide.data-v-83a5a03c {
  height: 200rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 40rpx;
  border-radius: 16rpx;
}
.swiper-text.data-v-83a5a03c {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}
.swiper-desc.data-v-83a5a03c {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 项目卡片 */
.project-card.data-v-83a5a03c {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  margin: 20rpx 30rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}
.project-info.data-v-83a5a03c {
  flex: 1;
}
.project-name.data-v-83a5a03c {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.project-addr.data-v-83a5a03c {
  display: block;
  font-size: 24rpx;
  color: #999;
}
.project-switch.data-v-83a5a03c {
  padding: 12rpx 24rpx;
  background: rgba(229, 57, 53, 0.1);
  border-radius: 30rpx;
}
.project-switch text.data-v-83a5a03c {
  font-size: 26rpx;
  color: #e53935;
}

/* 区块 */
.section.data-v-83a5a03c {
  background: #fff;
