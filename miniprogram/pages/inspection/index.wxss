
.page.data-v-042a83e3 {
  width: 100%;
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}
.content.data-v-042a83e3 {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-top: calc(14px + env(safe-area-inset-top));
}

/* 搜索栏 */
.search-bar.data-v-042a83e3 {
  display: flex;
  /* width: 94%; */
  align-items: center;
  background: #fff;
  padding: 16rpx 20rpx;
  gap: 16rpx;
}
.search-bar.data-v-042a83e3 .uni-searchbar {
  flex: 1;
  padding: 0;
}
.search-bar.data-v-042a83e3 .uni-searchbar__box {
  background: #f5f5f5;
  border-radius: 40rpx;
}
.date-picker.data-v-042a83e3 {
  width: 80rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 12rpx;
}

/* 列表容器 */
.list-container.data-v-042a83e3 {
  flex: 1;
  width: 100%;
  padding: 20rpx;
  padding-right: 20rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.inspection-card.data-v-042a83e3 {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.card-header.data-v-042a83e3 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.title-row.data-v-042a83e3 {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.title.data-v-042a83e3 {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
.tag.data-v-042a83e3 {
  font-size: 24rpx;
  color: #999;
}
.date.data-v-042a83e3 {
  font-size: 24rpx;
  color: #999;
}
.card-content.data-v-042a83e3 {
  padding: 20rpx 24rpx;
}
.info-row.data-v-042a83e3 {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}
.label.data-v-042a83e3 {
  width: 140rpx;
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}
.value.data-v-042a83e3 {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}
.count.data-v-042a83e3 {
  font-size: 26rpx;
  color: #333;
  margin-left: 20rpx;
}
.status-badge.data-v-042a83e3 {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}
.status-normal.data-v-042a83e3 {
  background: rgba(76, 175, 80, 0.1);
  color: #4caf50;
}
.status-error.data-v-042a83e3 {
  background: rgba(244, 67, 54, 0.1);
  color: #f44336;
}

/* 空状态 */
.empty-state.data-v-042a83e3 {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}
.empty-text.data-v-042a83e3 {
  font-size: 28rpx;
  color: #999;
}

/* 加载更多 */
.loading-more.data-v-042a83e3,
.no-more.data-v-042a83e3 {
  text-align: center;
  padding: 30rpx 0;
}
.loading-more text.data-v-042a83e3,
.no-more text.data-v-042a83e3 {
  font-size: 26rpx;
  color: #999;
}

/* 日期弹窗 */
.date-popup.data-v-042a83e3 {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}
.popup-header.data-v-042a83e3 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}
.popup-header text.data-v-042a83e3 {
  font-size: 28rpx;
  color: #e53935;
}
.popup-title.data-v-042a83e3 {
  color: #333 !important;
  font-weight: bold;
}
.picker-view.data-v-042a83e3 {
  height: 400rpx;
}
.picker-item.data-v-042a83e3 {
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
}

/* 覆盖 uni-nav-bar 标题样式 */
.data-v-042a83e3 .uni-nav-bar-text {
  font-size: 36rpx !important;
  font-weight: bold !important;
}
.data-v-042a83e3 .uni-navbar__header-container {
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  display: flex !important;
  justify-content: center !important;
  pointer-events: none;
}
.data-v-042a83e3 .uni-navbar__header-container-inner {
  pointer-events: auto;
}
.data-v-042a83e3 .uni-navbar__header-btns-left {
  z-index: 10 !important;
  position: relative !important;
}
