
.page.data-v-6705acfc {
  width: 100vw;
  height: 100vh;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 覆盖 uni-nav-bar 标题样式 */
.data-v-6705acfc .uni-nav-bar-text {
  font-size: 36rpx !important;
  font-weight: bold !important;
}

/* 让标题容器绝对定位实现真正居中 */
.data-v-6705acfc .uni-navbar__header-container {
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  display: flex !important;
  justify-content: center !important;
  pointer-events: none;
}
.data-v-6705acfc .uni-navbar__header-container-inner {
  pointer-events: auto;
}

/* 确保左侧按钮在标题容器之上可点击 */
.data-v-6705acfc .uni-navbar__header-btns-left {
  z-index: 10 !important;
  position: relative !important;
}

/* 内容区域/卡片列表容器 */
.content.data-v-6705acfc {
  flex: 1;
  padding: 20rpx;
  padding-top: calc(16px + env(safe-area-inset-top));
  background: #f5f5f5;
  box-sizing: border-box;
}
.building-card.data-v-6705acfc {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.card-header.data-v-6705acfc {
  background: linear-gradient(135deg, #e53935 0%, #ef5350 100%);
  padding: 20rpx 30rpx;
}
.building-name.data-v-6705acfc {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}
.card-content.data-v-6705acfc {
  padding: 20rpx 30rpx;
}
.info-row.data-v-6705acfc {
  display: flex;
  margin-bottom: 16rpx;
}
.info-row.data-v-6705acfc:last-child {
  margin-bottom: 0;
}
.info-item.data-v-6705acfc {
  flex: 1;
  display: flex;
}
.info-label.data-v-6705acfc {
  font-size: 26rpx;
  color: #666;
  margin-right: 10rpx;
}
.info-value.data-v-6705acfc {
  font-size: 26rpx;
  color: #333;
}

/* 空状态 */
.empty-state.data-v-6705acfc {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}
.empty-text.data-v-6705acfc {
  font-size: 28rpx;
  color: #999;
}

/* 添加按钮 */
.add-btn.data-v-6705acfc {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #e53935 0%, #ef5350 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(229, 57, 53, 0.4);
  z-index: 100;
}
.add-icon.data-v-6705acfc {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
}
