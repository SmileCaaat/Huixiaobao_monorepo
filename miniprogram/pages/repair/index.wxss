
.page.data-v-3ef94d39 {
  min-height: 100vh;
  background: #f5f6f7;
  display: flex;
  flex-direction: column;
}
.stats-header.data-v-3ef94d39 {
  background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
  display: flex;
  padding: 30rpx 0;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(211, 47, 47, 0.2);
}
.stat-item.data-v-3ef94d39 {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.border-left.data-v-3ef94d39 {
  border-left: 1rpx solid rgba(255, 255, 255, 0.2);
}
.stat-num.data-v-3ef94d39 {
  font-size: 36rpx;
  font-weight: bold;
}
.stat-label.data-v-3ef94d39 {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

/* 选项卡 */
.tabs.data-v-3ef94d39 {
  background: #fff;
  display: flex;
  height: 90rpx;
  position: sticky;
  top: calc(44px + env(safe-area-inset-top));
  z-index: 10;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}
.tab-item.data-v-3ef94d39 {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.tab-item.active.data-v-3ef94d39 {
  color: #e53935;
  font-weight: bold;
}
.tab-item.active.data-v-3ef94d39::after {
  content: "";
  position: absolute;
  bottom: 0;
  width: 60rpx;
  height: 6rpx;
  background: #e53935;
  border-radius: 3rpx;
}
.badge.data-v-3ef94d39 {
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 0 10rpx;
  border-radius: 20rpx;
  margin-left: 8rpx;
  min-width: 24rpx;
  text-align: center;
}
.badge.gray.data-v-3ef94d39 {
  background: #bfbfbf;
}

/* 列表 */
.list-container.data-v-3ef94d39 {
  flex: 1;
  height: 0; /* 配合flex: 1使用 */
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}
.repair-card.data-v-3ef94d39 {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.card-header.data-v-3ef94d39 {
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}
.urgency.data-v-3ef94d39 {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}
.level-1.data-v-3ef94d39 {
  background: #e6f7ff;
  color: #1890ff;
}
.level-2.data-v-3ef94d39 {
  background: #fff7e6;
  color: #fa8c16;
}
.level-3.data-v-3ef94d39 {
  background: #fff1f0;
  color: #f5222d;
}
.status-tag.data-v-3ef94d39 {
  font-size: 24rpx;
}
.status-0.data-v-3ef94d39 {
  color: #faad14;
} /* 待处理 */
.status-1.data-v-3ef94d39 {
  color: #1890ff;
} /* 处理中 */
.status-2.data-v-3ef94d39 {
  color: #52c41a;
} /* 已完成 */
.card-body.data-v-3ef94d39 {
  padding: 24rpx;
}
.info-row.data-v-3ef94d39 {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}
.info-label.data-v-3ef94d39 {
  color: #999;
  flex-shrink: 0;
}
.info-value.data-v-3ef94d39 {
  color: #333;
}
.ellipsis.data-v-3ef94d39 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.text-gray.data-v-3ef94d39 {
  color: #999;
}
.card-footer.data-v-3ef94d39 {
  padding: 20rpx 24rpx;
  background: #fafafa;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.reporter.data-v-3ef94d39 {
  font-size: 24rpx;
  color: #666;
}

/* 悬浮按钮 */
.fab.data-v-3ef94d39 {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 110rpx;
  height: 110rpx;
  background: #e53935;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(229, 57, 53, 0.4);
  z-index: 100;
}

/* 空状态 */
.empty-state.data-v-3ef94d39 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-img.data-v-3ef94d39 {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}
.empty-text.data-v-3ef94d39 {
  font-size: 28rpx;
  color: #999;
}
