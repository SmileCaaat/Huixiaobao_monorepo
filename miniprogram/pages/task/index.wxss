
.page.data-v-0fef721e {
  width: 100vw;
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 内容区域 */
.content.data-v-0fef721e {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-top: calc(16px + env(safe-area-inset-top));
  overflow: hidden;
}

/* Tab 切换 */
.tab-wrapper.data-v-0fef721e {
  display: flex;
  background: #fff;
  padding: 0 30rpx;
}
.tab-item.data-v-0fef721e {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}
.tab-item text.data-v-0fef721e {
  font-size: 30rpx;
  color: #666;
}
.tab-item.active text.data-v-0fef721e {
  color: #e53935;
  font-weight: bold;
}
.tab-line.data-v-0fef721e {
  position: absolute;
  bottom: 0;
  width: 80rpx;
  height: 6rpx;
  background: #e53935;
  border-radius: 3rpx;
}

/* 任务列表 */
.task-list.data-v-0fef721e {
  flex: 1;
  padding: 20rpx;
}

/* 任务卡片 */
.task-card.data-v-0fef721e {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  position: relative;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.task-title.data-v-0fef721e {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-right: 120rpx;
}
.task-info.data-v-0fef721e {
  margin-bottom: 12rpx;
}
.info-text.data-v-0fef721e {
  font-size: 26rpx;
  color: #666;
}

/* 任务状态 */
.task-status.data-v-0fef721e {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}
.task-status text.data-v-0fef721e {
  font-size: 24rpx;
}
.status-pending.data-v-0fef721e {
  background: rgba(158, 158, 158, 0.1);
}
.status-pending text.data-v-0fef721e {
  color: #9e9e9e;
}
.status-running.data-v-0fef721e {
  background: rgba(255, 152, 0, 0.1);
}
.status-running text.data-v-0fef721e {
  color: #ff9800;
}
.status-completed.data-v-0fef721e {
  background: rgba(76, 175, 80, 0.1);
}
.status-completed text.data-v-0fef721e {
  color: #4caf50;
}
.status-overdue.data-v-0fef721e {
  background: rgba(244, 67, 54, 0.1);
}
.status-overdue text.data-v-0fef721e {
  color: #f44336;
}

/* 加载更多 */
.loading-more.data-v-0fef721e {
  text-align: center;
  padding: 30rpx;
}
.loading-more text.data-v-0fef721e {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-state.data-v-0fef721e {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}
.empty-text.data-v-0fef721e {
  font-size: 28rpx;
  color: #999;
}

/* 覆盖 uni-nav-bar 样式 */
.data-v-0fef721e .uni-nav-bar-text {
  font-size: 36rpx !important;
  font-weight: bold !important;
}
.data-v-0fef721e .uni-navbar__header-container {
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  display: flex !important;
  justify-content: center !important;
  pointer-events: none;
}
.data-v-0fef721e .uni-navbar__header-container-inner {
  pointer-events: auto;
}
.data-v-0fef721e .uni-navbar__header-btns-left {
  z-index: 10 !important;
  position: relative !important;
}
