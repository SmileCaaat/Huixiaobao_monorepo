
.page.data-v-2ecdcd3f {
  width: 100vw;
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 内容区域 */
.content.data-v-2ecdcd3f {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-top: calc(16px + env(safe-area-inset-top));
  overflow: hidden;
}

/* 系统标题头部 */
.system-header.data-v-2ecdcd3f {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.header-icon.data-v-2ecdcd3f {
  font-size: 32rpx;
}
.header-title.data-v-2ecdcd3f {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 设备列表 */
.device-list.data-v-2ecdcd3f {
  flex: 1;
  background: #fff;
}

/* 设备卡片 */
.device-card.data-v-2ecdcd3f {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}
.device-card.data-v-2ecdcd3f:active {
  background: #f9f9f9;
}
.device-header.data-v-2ecdcd3f {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.device-name.data-v-2ecdcd3f {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
.device-tag.data-v-2ecdcd3f {
  font-size: 22rpx;
  color: #999;
  padding: 4rpx 12rpx;
  background: #f5f5f5;
  border-radius: 4rpx;
}
.device-stats.data-v-2ecdcd3f {
  display: flex;
  gap: 30rpx;
}
.stat-item.data-v-2ecdcd3f {
  font-size: 26rpx;
  color: #1976d2;
}
.firetest .stat-item.data-v-2ecdcd3f {
  color: #f57c00;
}

/* 右侧状态和箭头 */
.device-right.data-v-2ecdcd3f {
  position: absolute;
  top: 50%;
  right: 30rpx;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.status-badge.data-v-2ecdcd3f {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}
.status-badge text.data-v-2ecdcd3f {
  font-size: 24rpx;
}
.status-badge.pending.data-v-2ecdcd3f {
  background: #e53935;
}
.firetest .status-badge.pending.data-v-2ecdcd3f {
  background: #f57c00;
}
.status-badge.pending text.data-v-2ecdcd3f {
  color: #fff;
}
.status-badge.completed.data-v-2ecdcd3f {
  background: rgba(76, 175, 80, 0.1);
}
.status-badge.completed text.data-v-2ecdcd3f {
  color: #4caf50;
}
.arrow.data-v-2ecdcd3f {
  font-size: 36rpx;
  color: #ccc;
}

/* 加载状态 */
.loading-state.data-v-2ecdcd3f {
  text-align: center;
  padding: 40rpx;
}
.loading-state text.data-v-2ecdcd3f {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-state.data-v-2ecdcd3f {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}
.empty-text.data-v-2ecdcd3f {
  font-size: 28rpx;
  color: #999;
}

/* 弹窗样式 */
.popup-content.data-v-2ecdcd3f {
  background-color: #fff;
  border-radius: 30rpx 30rpx 0 0;
  display: flex;
  flex-direction: column;
  max-height: 80vh;
}
.popup-header.data-v-2ecdcd3f {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.popup-title.data-v-2ecdcd3f {
  font-size: 32rpx;
  font-weight: bold;
}
.popup-close.data-v-2ecdcd3f {
  font-size: 40rpx;
  color: #999;
}
.popup-form.data-v-2ecdcd3f {
  flex: 1;
  padding: 30rpx;
}
.form-item.data-v-2ecdcd3f {
  margin-bottom: 30rpx;
}
.label.data-v-2ecdcd3f {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: bold;
}
.input.data-v-2ecdcd3f {
  height: 80rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}
.textarea.data-v-2ecdcd3f {
  width: 100%;
  height: 160rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.image-list.data-v-2ecdcd3f {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.image-item.data-v-2ecdcd3f {
  width: 160rpx;
  height: 160rpx;
  position: relative;
}
.image-item image.data-v-2ecdcd3f {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}
.delete-btn.data-v-2ecdcd3f {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
.image-add.data-v-2ecdcd3f {
  width: 160rpx;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #ccc;
}
.popup-footer.data-v-2ecdcd3f {
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}
.btn-submit.data-v-2ecdcd3f {
  background: #ff9800;
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
}
.action-btn-wrapper.data-v-2ecdcd3f {
  margin-right: 20rpx;
}
.btn-maintain.data-v-2ecdcd3f {
  background: #ff9800;
  color: #fff;
  font-size: 24rpx;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 28rpx;
  margin: 0;
}
.btn-maintain.data-v-2ecdcd3f:active {
  opacity: 0.8;
}
.firetest .device-name.data-v-2ecdcd3f {
  color: #e65100;
}
