
.page.data-v-588b9861 {
  width: 100vw;
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}
.content.data-v-588b9861 {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-top: calc(16px + env(safe-area-inset-top));
  overflow: hidden;
}
.item-list.data-v-588b9861 {
  flex: 1;
}
.item-card.data-v-588b9861 {
  background: #fff;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}
.item-top.data-v-588b9861 {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.item-info.data-v-588b9861 {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  padding-right: 20rpx;
}
.item-name.data-v-588b9861 {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
.item-code.data-v-588b9861 {
  font-size: 24rpx;
  color: #999;
}

/* 按钮组 */
.btn-group.data-v-588b9861 {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}
.check-btn.data-v-588b9861 {
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
  border: 2rpx solid;
}
.check-btn text.data-v-588b9861 {
  font-size: 24rpx;
}

/* 正常按钮 */
.check-btn.normal.data-v-588b9861 {
  border-color: #4caf50;
  color: #4caf50;
}
.firetest .check-btn.normal.data-v-588b9861 {
  border-color: #ff9800;
  color: #ff9800;
}
.firetest .check-btn.normal.active.data-v-588b9861 {
  background: #ff9800;
  color: #fff;
}
.check-btn.normal.active.data-v-588b9861 {
  background: #4caf50;
  color: #fff;
}
.check-btn.normal.active text.data-v-588b9861 {
  color: #fff;
}
.check-btn.normal text.data-v-588b9861 {
  color: #4caf50;
}

/* 故障按钮 */
.check-btn.fault.data-v-588b9861 {
  border-color: #ef5350;
  color: #ef5350;
}
.check-btn.fault.active.data-v-588b9861 {
  background: #ef5350;
  color: #fff;
}
.check-btn.fault.active text.data-v-588b9861 {
  color: #fff;
}
.check-btn.fault text.data-v-588b9861 {
  color: #ef5350;
}

/* 无此设备按钮 */
.check-btn.none.data-v-588b9861 {
  border-color: #ffd740;
  color: #ffca28;
}
.check-btn.none.active.data-v-588b9861 {
  background: #ffd740;
  color: #333;
}
.check-btn.none.active text.data-v-588b9861 {
  color: #333;
}
.check-btn.none text.data-v-588b9861 {
  color: #f9a825;
}

/* 故障描述区域 */
.fault-area.data-v-588b9861 {
  margin-top: 20rpx;
}
.fault-input.data-v-588b9861 {
  width: 100%;
  min-height: 120rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  background: #fafafa;
}
.save-btn.data-v-588b9861 {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  padding: 10rpx 24rpx;
  background: #009688;
  border-radius: 6rpx;
}
.save-btn text.data-v-588b9861 {
  color: #fff;
  font-size: 24rpx;
}

/* 弹窗样式 */
.modal-overlay.data-v-588b9861 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-content.data-v-588b9861 {
  width: 85%;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  max-height: 80vh;
}
.modal-header.data-v-588b9861 {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.modal-title.data-v-588b9861 {
  font-size: 32rpx;
  font-weight: bold;
}
.close-icon.data-v-588b9861 {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}
.modal-body.data-v-588b9861 {
  flex: 1;
  height: 0;
}
.modal-padding.data-v-588b9861 {
  padding: 30rpx;
}
.form-item.data-v-588b9861 {
  margin-bottom: 30rpx;
}
.form-label.data-v-588b9861 {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}
.radio-group.data-v-588b9861 {
  display: flex;
  gap: 40rpx;
}
.radio-item.data-v-588b9861 {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.radio-circle.data-v-588b9861 {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #1976d2;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.radio-inner.data-v-588b9861 {
  width: 20rpx;
  height: 20rpx;
  background: #1976d2;
  border-radius: 50%;
}
.picker-view.data-v-588b9861 {
  border: 2rpx solid #ddd;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.form-textarea.data-v-588b9861 {
  width: 100%;
  height: 160rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}
.upload-area.data-v-588b9861 {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.upload-btn.data-v-588b9861 {
  padding: 12rpx 24rpx;
  border: 2rpx solid #ddd;
  border-radius: 6rpx;
  font-size: 26rpx;
  color: #333;
}
.modal-footer.data-v-588b9861 {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}
.btn-cancel.data-v-588b9861,
.btn-confirm.data-v-588b9861 {
  padding: 12rpx 36rpx;
  border-radius: 6rpx;
  font-size: 28rpx;
}
.btn-cancel.data-v-588b9861 {
  border: 2rpx solid #ddd;
  color: #666;
}
.btn-confirm.data-v-588b9861 {
  background: #1976d2;
  color: #fff;
  border: 2rpx solid #1976d2;
}
.firetest .btn-confirm.data-v-588b9861 {
  background: #ff9800;
  border-color: #ff9800;
}
.firetest .radio-circle.data-v-588b9861 {
  border-color: #ff9800;
}
.firetest .radio-inner.data-v-588b9861 {
  background: #ff9800;
}

/* 覆盖 uni-nav-bar 样式 */
.data-v-588b9861 .uni-nav-bar-text {
  font-size: 36rpx !important;
  font-weight: bold !important;
}
.data-v-588b9861 .uni-navbar__header-container {
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  display: flex !important;
  justify-content: center !important;
  pointer-events: none;
}
.data-v-588b9861 .uni-navbar__header-container-inner {
  pointer-events: auto;
}
.data-v-588b9861 .uni-navbar__header-btns-left {
  z-index: 10 !important;
  position: relative !important;
}
