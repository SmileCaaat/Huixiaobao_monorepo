
.phone-login-container.data-v-ca029e96 {
  min-height: 100vh;
  background: #fff;
}

/* 顶部导航 */
.header.data-v-ca029e96 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
}
.back-btn.data-v-ca029e96 {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #333;
}
.header-title.data-v-ca029e96 {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}
.placeholder.data-v-ca029e96 {
  width: 60rpx;
}

/* 表单区域 */
.form-section.data-v-ca029e96 {
  padding: 60rpx 50rpx;
}
.form-title.data-v-ca029e96 {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.form-subtitle.data-v-ca029e96 {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 80rpx;
}

/* 输入框组 */
.input-group.data-v-ca029e96 {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #eee;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}
.input-prefix.data-v-ca029e96 {
  font-size: 32rpx;
  color: #333;
  padding-right: 20rpx;
  border-right: 2rpx solid #eee;
  margin-right: 20rpx;
}
.input-field.data-v-ca029e96 {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}
.code-input.data-v-ca029e96 {
  margin-right: 20rpx;
}
.clear-btn.data-v-ca029e96 {
  width: 40rpx;
  height: 40rpx;
  background: #ccc;
  border-radius: 50%;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.code-btn.data-v-ca029e96 {
  font-size: 28rpx;
  color: #e53935;
  white-space: nowrap;
}
.code-btn.disabled.data-v-ca029e96 {
  color: #999;
}

/* 提交按钮 */
.submit-btn.data-v-ca029e96 {
  width: 100%;
  height: 100rpx;
  background: #ccc;
  border-radius: 50rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 60rpx;
}
.submit-btn.active.data-v-ca029e96 {
  background: linear-gradient(90deg, #e53935 0%, #ef5350 100%);
  box-shadow: 0 8rpx 24rpx rgba(229, 57, 53, 0.35);
}
.submit-btn.data-v-ca029e96::after {
  border: none;
}

/* 提示文字 */
.tips.data-v-ca029e96 {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 30rpx;
}
