# Copy this file to config.env and edit values.
# ASCII only. Do not commit config.env.

# Local dashboard / gateway port
DASHBOARD_PORT=3080

# Backend HTTP port (must match backend application.yml)
BACKEND_PORT=83
BACKEND_HOST=127.0.0.1

# MySQL for local backend
# Local installer docs use root password Huixiaobao@123 in config.env (gitignored); keep example as replace-me.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dev_manager
DB_USER=root
DB_PASS=replace-me
DRUID_USER=admin
DRUID_PASS=admin@123456

# Auto start backend jar when start.bat runs (1=yes, 0=no)
# Prefer 0: use dashboard buttons (clean+package, then start backend)
AUTO_START_BACKEND=0

# Legacy flag (unused by dashboard start button; packaging is a separate button)
AUTO_BUILD_BACKEND=0

# Switch miniprogram BASE_URL to local backend (1=yes, 0=no)
SWITCH_MINIPROGRAM=1

# Miniprogram local API base (use LAN IP for real device testing)
MINIPROGRAM_BASE_URL=http://127.0.0.1:83
MINIPROGRAM_PROD_URL=https://huixiaobao-admin.site

# Open browser after start (1=yes, 0=no)
OPEN_BROWSER=1

# Demo devices when backend is offline (1=yes, 0=no)
DEMO_DEVICES=1

# Optional: WeChat DevTools CLI path (cli.bat). Leave empty to auto-detect.
# Example: D:\CriticalApplication\???web?????????\cli.bat
WECHAT_DEVTOOLS_CLI=
